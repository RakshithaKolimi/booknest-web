{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"], // ✅ allows localStorage, window, document, etc.
    "jsx": "react-jsx", // ✅ new JSX transform
    "moduleResolution": "bundler", // ✅ proper module lookup in monorepo
    "strict": true, // ✅ enables strict type checking
    "esModuleInterop": true, // ✅ ensures clean imports from commonjs packages
    "skipLibCheck": true, // ✅ faster build (recommended for monorepos)
    "forceConsistentCasingInFileNames": true // ✅ ensures consistent imports across OS
  },
  "include": ["src", "global.d.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
